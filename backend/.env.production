# =============================================================================
# Enterprise RAG AI Assistant — Production Environment Variables
# =============================================================================
# Copy this file to .env or load it into your production container manager.
# DO NOT commit real secrets to version control.
# =============================================================================

APP_NAME="Enterprise RAG AI Assistant"
ENVIRONMENT=production
DEBUG=false

# Server Configurations
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# API Documentation (disable Swagger/ReDoc in production for security hardening)
DOCS_URL=
REDOC_URL=

# CORS
# Comma-separated allowed origins (Replace with your company's actual domains)
ALLOWED_ORIGINS=https://rag.mycompany.com,https://api-rag.mycompany.com

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# Database
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Database password must be strong and distinct.
DATABASE_URL=postgresql+asyncpg://raguser:PRODUCTION_SECURE_PASSWORD@postgres:5432/ragdb

# Security Secrets
# Generate a strong 32-byte secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=PLACEHOLDER_GENERATE_WITH_SECRET_IN_PRODUCTION

# Token Expiries
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Caching & Rate Limits
ENABLE_REDIS_CACHING=true
REDIS_CACHE_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_SIZE_BYTES=2097152

# Database Connection Pooling
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis/Worker
REDIS_URL=redis://redis:6379/0

# LLM Providers (Configure active keys here)
# GEMINI_API_KEY=AIzaSy...
# OPENAI_API_KEY=sk-...
