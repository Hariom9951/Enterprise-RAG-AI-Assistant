# =============================================================================
# Enterprise RAG AI Assistant — Production Environment Variables
# =============================================================================
# This file is a TEMPLATE only. Do NOT commit real secrets to source control.
#
# ── Hugging Face Spaces deployment ──────────────────────────────────────────
# All secrets below must be added via the HF Spaces "Repository Secrets" UI:
#   https://huggingface.co/spaces/<your-username>/<your-space>/settings
#
# HF Spaces injects secrets as real environment variables (highest priority),
# so they override any values in this file.
#
# Required secrets to configure in HF Spaces:
#   DATABASE_URL   — Neon PostgreSQL connection string
#   REDIS_URL      — Upstash Redis TLS connection string
#   SECRET_KEY     — JWT signing secret (32-byte hex)
#   GEMINI_API_KEY — Google AI Studio API key
# =============================================================================

APP_NAME="Enterprise RAG AI Assistant"
ENVIRONMENT=production
DEBUG=false

# Server — port 7860 is required by Hugging Face Spaces Docker SDK
HOST=0.0.0.0
PORT=7860
WORKERS=1
RELOAD=false

# API Documentation
DOCS_URL=/docs
REDOC_URL=/redoc

# CORS — set to your frontend domain in production
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-domain.com
ALLOWED_ORIGINS=*

# Logging — stdout-only (no file) for container environments
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=

# Database (Neon PostgreSQL)
# Format: postgresql+asyncpg://<user>:<password>@<host>/<dbname>?sslmode=require&channel_binding=require
# Set this via HF Spaces Secrets UI — do NOT hardcode real credentials here.
DATABASE_URL=postgresql+asyncpg://CHANGE_ME:CHANGE_ME@CHANGE_ME.neon.tech/neondb?sslmode=require&channel_binding=require

# Security Secrets
# Generate a strong 32-byte secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Set this via HF Spaces Secrets UI.
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# Token Expiries
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Caching & Rate Limits
ENABLE_REDIS_CACHING=true
REDIS_CACHE_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_SIZE_BYTES=2097152

# Database Connection Pooling
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis / Upstash (TLS — note the rediss:// scheme)
# Set this via HF Spaces Secrets UI — do NOT hardcode real credentials here.
REDIS_URL=rediss://default:CHANGE_ME@CHANGE_ME.upstash.io:6379

# LLM Providers — set real keys via HF Spaces Secrets UI
# GEMINI_API_KEY=AIzaSy...
# OPENAI_API_KEY=sk-...
