# Ignore virtual environments
venv/
.venv/
env/

# Ignore databases and sqlite files
*.db
*.db-journal

# Ignore local storage and logs
storage/
logs/
temp/
uploads/
processed/
failed/

# Ignore cache directories
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Ignore git
.git/
.github/

# Ignore local config files (secrets must come from HF Spaces Secrets UI or env vars)
.env
.env.production
.env.development
.env.staging

# Ignore test artifacts (not needed at runtime)
tests/

# Ignore alembic version scripts (applied via CMD entrypoint, not baked in)
# Keep alembic.ini and alembic/ directory for migration runner
# Exclude only the __pycache__ inside alembic
alembic/__pycache__/

