# =============================================================================
# Enterprise RAG AI Assistant — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All variables here are loaded via pydantic-settings in app/config/settings.py
#
# ── Hugging Face Spaces deployment ──────────────────────────────────────────
# Configure secrets via the HF Spaces "Repository Secrets" UI instead of .env:
#   https://huggingface.co/spaces/<your-username>/<your-space>/settings
#
# Required secrets for HF Spaces: DATABASE_URL, REDIS_URL, SECRET_KEY, GEMINI_API_KEY
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Enterprise RAG AI Assistant"
APP_VERSION="0.2.0"
APP_DESCRIPTION="Production-ready Enterprise RAG AI Assistant API"
DEBUG=false
ENVIRONMENT=development             # development | staging | production

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=7860                           # 7860 for Hugging Face Spaces; 8000 for local Docker Compose
WORKERS=1                           # Increase for production (e.g. 4)
RELOAD=false                        # Hot-reload — enable only in development

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_V1_PREFIX=/api/v1
DOCS_URL=/docs                      # Set to "" to disable Swagger UI in prod
REDOC_URL=/redoc                    # Set to "" to disable ReDoc in prod

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# CORS settings support both comma-separated lists and JSON arrays.
# Comma-separated format (recommended):
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
ALLOWED_HEADERS=*
ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                     # text | json  (use json in production / HF Spaces)
LOG_FILE_PATH=                      # Empty = stdout only (recommended for containers)
                                    # Set to logs/app.log for local file logging

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local development (Docker Compose):
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb

# Neon PostgreSQL (production / HF Spaces):
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require&channel_binding=require

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# JWT signing algorithm. Change to RS256 for asymmetric (requires key files).
ALGORITHM=HS256

# Access token TTL in minutes (default: 30 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token TTL in days (default: 7 days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Redis / Cache
# -----------------------------------------------------------------------------
# Local development (Docker Compose):
REDIS_URL=redis://localhost:6379/0

# Upstash Redis (production / HF Spaces — note rediss:// TLS scheme):
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Embedding Model
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=cpu
