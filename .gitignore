# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
*.egg-link
*.pth

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# Distribution / packaging
.Python
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# Spyder project settings
.spyderproject.db
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# PyCharm
.idea/

# -----------------------------------------------------------------------------
# Node.js / Next.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/
.pnp.*

# Next.js build output
.next/
out/
build/

# Production
dist/

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Vercel
.vercel

# Turborepo
.turbo

# SvelteKit / Nuxt (in case of future additions)
.svelte-kit
.nuxt

# dotenv files (keep .env.example committed)
.env.local
.env.development.local
.env.test.local
.env.production.local

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# JetBrains IDEs
.idea/
*.iws
*.iml
*.ipr

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
*.sublime-project

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
log/

# -----------------------------------------------------------------------------
# Secrets & Certificates
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.crt
secrets/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
.sass-cache/
*.pid
*.seed
*.pid.lock
lib-cov/

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
# Uploaded file storage (generated at runtime — not source code)
backend/storage/

# SQLite local dev database
*.db
*.sqlite
*.sqlite3

# Alembic compiled artifacts (keep migrations, ignore runtime cache)
backend/alembic/__pycache__/

# Tasks package init (auto-generated)
backend/app/tasks/__init__.py
