# =============================================================================
# Enterprise RAG AI Assistant — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All variables here are loaded via pydantic-settings in app/config/settings.py
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Enterprise RAG AI Assistant"
APP_VERSION="0.1.0"
APP_DESCRIPTION="Production-ready Enterprise RAG AI Assistant API"
DEBUG=false
ENVIRONMENT=development             # development | staging | production

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1                           # Increase for production (e.g. 4)
RELOAD=false                        # Hot-reload — enable only in development

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_V1_PREFIX=/api/v1
DOCS_URL=/docs                      # Set to "" to disable Swagger UI in prod
REDOC_URL=/redoc                    # Set to "" to disable ReDoc in prod

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins.
# Use "*" only for development. Always restrict in production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
ALLOWED_HEADERS=*
ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                     # text | json  (use json in production)
LOG_FILE_PATH=logs/app.log          # Set to "" to disable file logging

# -----------------------------------------------------------------------------
# Security (Placeholders — implement in Phase 2)
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Database (Placeholders — implement in Phase 3)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rag_db
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Vector Store (Placeholders — implement in Phase 4)
# -----------------------------------------------------------------------------
# VECTOR_STORE_TYPE=pgvector          # pgvector | pinecone | weaviate | chroma
# VECTOR_STORE_URL=

# -----------------------------------------------------------------------------
# LLM Provider (Placeholders — implement in Phase 4)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Redis / Cache (Placeholders — implement in Phase 3)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
